# ── BriefAI .gitignore ────────────────────────────────────────────────────────

# Environment & secrets
.env
.env.*
*.key

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
wheels/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Audio & video files (user uploads — can be large)
*.mp3
*.mp4
*.wav
*.m4a
*.ogg
*.flac
*.webm
*.mkv

# Whisper model cache
~/.cache/whisper/

# HuggingFace model cache
~/.cache/huggingface/

# ChromaDB local vector store
chroma_db/
*.chroma
.chroma/

# Transcripts & exports (generated at runtime)
transcripts/
exports/
outputs/
*.pdf

# Streamlit
.streamlit/secrets.toml

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDEs
.vscode/
.idea/
*.swp
*.swo